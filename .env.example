# ============================================================
# CRUISE CONNECT HUB — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PAYSTACK ─────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_KEY_HERE
PAYSTACK_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
# For testing: use pk_test_ and sk_test_ keys
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_TEST_KEY
# PAYSTACK_SECRET_KEY=sk_test_YOUR_TEST_SECRET

# Webhook secret (from Paystack dashboard → Webhooks)
PAYSTACK_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── FLUTTERWAVE (Recommended) ────────────────────────────────
# Get from: https://dashboard.flutterwave.com/
FLW_SECRET_KEY=FLWSECK_LIVE_...
FLW_WEBHOOK_SECRET=YOUR_FLW_WEBHOOK_SECRET
FLW_CURRENCY=NGN

# Server-side minimum withdrawal amount (NGN)
MIN_WITHDRAWAL_NGN=100

# Optional UI hint (client-side)
NEXT_PUBLIC_MIN_WITHDRAWAL=100

# ── APP CONFIG ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cruise-connect-hub.vercel.app
# For local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase API schema (optional)
# Only set this if your Supabase "Exposed schemas" requires a specific schema, and that schema is exposed.
# If you see "Invalid schema: public" in production, either:
# 1) Add `public` to Supabase Settings → API → Exposed schemas, or
# 2) Set NEXT_PUBLIC_SUPABASE_SCHEMA to a NON-public exposed schema name (for example: api)
# 3) If you use default public schema, leave NEXT_PUBLIC_SUPABASE_SCHEMA unset
# NEXT_PUBLIC_SUPABASE_SCHEMA=api

# Admin allowlist (recommended): only these users can access /admin, /moderator, /api/admin/*
# Use a comma-separated list of Supabase Auth user IDs (UUIDs). Keep this server-only in Vercel env vars.
ADMIN_USER_IDS=
# Optional strict admin X-handle allowlist (used when ADMIN_USER_IDS is empty)
# ADMIN_X_HANDLES=@TheCruiseCH,@13fxiii_
# Optional: private allowlist for /messages/group/cchp (defaults to ADMIN_USER_IDS when empty)
CCHP_MEMBER_IDS=
# Optional handle allowlist for /messages/group/cchp (comma-separated, with or without @)
CCHP_MEMBER_HANDLES=

# Admin passcode for /admin route
ADMIN_SECRET_KEY=YOUR_ADMIN_SECRET_HERE

# ── OPTIONAL: ANALYTICS ──────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── NOTES ────────────────────────────────────────────────────
# 1. Never commit .env.local to git — it's in .gitignore already
# 2. Set these vars in Vercel: Project → Settings → Environment Variables
# 3. After setting Supabase vars, run supabase-schema.sql in the SQL editor
# 4. For Paystack webhooks, set URL to: YOUR_APP_URL/api/paystack/webhook

# ── X / TWITTER OAUTH + FEED SYNC ────────────────────────────
# OAuth (required if users sign in with X through custom flow routes)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
# Optional aliases (kept for compatibility across teams/tools)
X_CLIENT_ID=your_twitter_client_id
X_CLIENT_SECRET=your_twitter_client_secret

# Optional for /api/spaces/sync route
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
COMMUNITY_X_HANDLE=TheCruiseCH

# Optional for /api/community/seed-xai route (AI-assisted ingest from your X community)
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-3-mini
COMMUNITY_X_URL=https://x.com/i/communities/1897164314764579242
# Supabase profile UUID used as "system author" when importing community posts
COMMUNITY_SEED_AUTHOR_ID=
# Alternative: seed by existing @handle (for X-first profile flows)
# IMPORTANT: use @handle only (example: @TheCruiseCH), not a full https://x.com/... URL
COMMUNITY_SEED_AUTHOR_HANDLE=@TheCruiseCH

# Protect cron/automation routes
CRON_SECRET=replace_with_long_random_secret

# Optional external movie app integration (NyumatFlix fork deployment URL)
NEXT_PUBLIC_CRUISE_CINEMA_URL=https://your-cruise-cinema-app.vercel.app

# ── LEGAL DOCS ───────────────────────────────────────────────
TERMS_OF_SERVICE_URL=https://cruise-connect-hub.vercel.app/terms-of-service.md
PRIVACY_POLICY_URL=https://cruise-connect-hub.vercel.app/privacy-policy.md
