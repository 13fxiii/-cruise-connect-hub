# ============================================================
# CRUISE CONNECT HUB — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PAYSTACK ─────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_KEY_HERE
PAYSTACK_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
# For testing: use pk_test_ and sk_test_ keys
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_TEST_KEY
# PAYSTACK_SECRET_KEY=sk_test_YOUR_TEST_SECRET

# Webhook secret (from Paystack dashboard → Webhooks)
PAYSTACK_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── APP CONFIG ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cruise-connect-hub.netlify.app
# For local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Minimum withdrawal amount in Naira
NEXT_PUBLIC_MIN_WITHDRAWAL=1000

# Admin passcode for /admin route
ADMIN_SECRET_KEY=YOUR_ADMIN_SECRET_HERE

# ── OPTIONAL: ANALYTICS ──────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── NOTES ────────────────────────────────────────────────────
# 1. Never commit .env.local to git — it's in .gitignore already
# 2. Set these vars in Netlify: Site settings → Environment variables
# 3. After setting Supabase vars, run supabase-schema.sql in the SQL editor
# 4. For Paystack webhooks, set URL to: YOUR_APP_URL/api/paystack/webhook

# ── X / TWITTER OAUTH ─────────────────────────────────────────
TWITTER_CLIENT_ID=OTZFOG85a29YZ1RwdTJteTIxQlI6MTpjaQ
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
