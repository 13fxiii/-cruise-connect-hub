{
  "name": "cruise-connect-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:static": "next build && next export",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "electron:dev": "electron electron/main.js",
    "electron:build": "electron-builder",
    "mobile:build": "npm run build:static && npx cap sync"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.11.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@vercel/speed-insights": "^2.0.0",
    "@xdevplatform/xdk": "^0.5.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.378.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.cruiseconnect.hub",
    "productName": "Cruise Connect Hub",
    "copyright": "Copyright © 2024 Cruise Connect Hub",
    "asar": true,
    "files": [
      "electron/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/icons"
    },
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "electron/icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "icon": "electron/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;Chat;",
      "desktop": {
        "Name": "Cruise Connect Hub",
        "Comment": "The home of Naija culture online",
        "Categories": "Network;Chat;"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icons/icon.ico",
      "uninstallerIcon": "electron/icons/icon.ico",
      "installerHeaderIcon": "electron/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cruise Connect Hub"
    },
    "publish": {
      "provider": "github",
      "owner": "13fxiii",
      "repo": "-cruise-connect-hub"
    }
  },
  "main": "electron/main.js",
  "overrides": {
    "brace-expansion": "^1.1.13",
    "picomatch": "^2.3.2",
    "@xmldom/xmldom": "^0.8.11",
    "lodash": "^4.17.21",
    "tar": "^7.5.12",
    "glob": "^10.4.5"
  }
}
